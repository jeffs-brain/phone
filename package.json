{
  "name": "jeff-phone",
  "version": "0.0.1",
  "private": true,
  "packageManager": "bun@1.3.8",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "prebuild": "expo prebuild",
    "check": "bun run typecheck --pretty false && bun test && bunx expo-doctor && bunx expo config --type public && git diff --check && bun pm untrusted",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "op-sqlite": {
    "sqliteVec": true,
    "fts5": true
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": ["@siteed/audio-studio"]
      }
    }
  },
  "dependencies": {
    "@callstack/liquid-glass": "0.7.1",
    "@config-plugins/react-native-webrtc": "^14.0.0",
    "@jeffs-brain/memory-react-native": "file:../memory/sdks/rn/memory",
    "@livekit/react-native": "^2.10.1",
    "@livekit/react-native-expo-plugin": "^1.0.2",
    "@livekit/react-native-webrtc": "^144.0.0",
    "@noble/hashes": "2.2.0",
    "@op-engineering/op-sqlite": "^15.2.11",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/netinfo": "11.5.2",
    "@siteed/audio-studio": "3.0.5",
    "base64-js": "^1.5.1",
    "expo": "~55.0.17",
    "expo-build-properties": "^55.0.0",
    "expo-constants": "^55.0.15",
    "expo-crypto": "~55.0.14",
    "expo-dev-client": "55.0.28",
    "expo-document-picker": "~55.0.13",
    "expo-file-system": "^55.0.17",
    "expo-font": "^55.0.6",
    "expo-image-manipulator": "^55.0.15",
    "expo-image-picker": "~55.0.19",
    "expo-linking": "^55.0.14",
    "expo-router": "^55.0.13",
    "expo-status-bar": "~55.0.5",
    "expo-system-ui": "^55.0.16",
    "livekit-client": "^2.18.6",
    "llama.rn": "0.12.0-rc.9",
    "nativewind": "4.2.3",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-audio-api": "^0.12.1",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
